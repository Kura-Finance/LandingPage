# Cloudflare Pages static headers (merged with Worker routeRules).
#
# IMPORTANT: public/404.html must exist so CF Pages does NOT SPA-fallback
# missing URLs (e.g. stale /_nuxt/*.js) to index.html as text/html.

/*
  Cache-Control: public, max-age=0, must-revalidate

/404.html
  Cache-Control: public, max-age=0, must-revalidate

/investors
  Cache-Control: public, max-age=0, must-revalidate

# Hashed build assets only — real files. Missing /_nuxt/* must 404 (see 404.html).
/_nuxt/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/_payload.json
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
